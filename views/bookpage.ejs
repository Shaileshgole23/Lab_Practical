<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% for(book for books){ %>
        <span>
           Title:<%= book.Title %><br>
           Author:<%= book.Author %><br>
           Genre :<%= book.genre %><br>
           Published:<%= book.published %><br>
           Rating:<%= book.rating %>
        </span>
    <% } %>
</body>
</html>