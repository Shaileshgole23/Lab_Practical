<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    <form action="/books" method="post">
    <div class="mb-3 row">
        <label for="staticEmail" class="col-sm-2 col-form-label">Title</label>
    <div class="col-sm-10">
        <input class="form-control" type="text" placeholder="Default input" aria-label="default input example" id="title" name="title">
    </div>
    </div>
    
    <div class="mb-3 row">
        <label for="staticEmail" class="col-sm-2 col-form-label">Author</label>
    <div class="col-sm-10">
        <input class="form-control" type="text" placeholder="Default input" aria-label="default input example" id="author",name="author">
    </div>
    </div>

    <div class="mb-3 row">
        <label for="staticEmail" class="col-sm-2 col-form-label">Genre</label>
    <div class="col-sm-10">
        <input class="form-control" type="text" placeholder="Default input" aria-label="default input example" id="genre",name="Genre">
    </div>
    </div>
    </form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>